# Copy this to .env and fill it in locally. Do not commit real credentials.
TITUSBOOKS_CONNECTIONSTRING=Host=localhost;Port=5432;Database=titusbooks;Username=postgres;Password=change-me
TITUSBOOKS_POSTGRES_SSL_MODE=Prefer
# TITUSBOOKS_POSTGRES_ROOT_CERTIFICATE=/etc/titusbooks/postgres-root.crt
TITUSBOOKS_RUN_MIGRATIONS=false
