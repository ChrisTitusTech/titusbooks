<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FinancialApp.Desktop.App"
             xmlns:local="using:FinancialApp.Desktop"
             RequestedThemeVariant="Light">
             <!-- Use a fixed light shell until the app has full theme-aware resources. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>
