<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FinancialApp.Desktop.ViewModels"
             xmlns:api="using:FinancialApp.Core.Api"
             x:Class="FinancialApp.Desktop.Views.AccountsView"
             x:DataType="vm:MainWindowViewModel">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="32,0,32,32"
              RowDefinitions="Auto,Auto,*"
              RowSpacing="14"
              MinHeight="470">
            <Grid ColumnDefinitions="*,160,190,Auto"
                  ColumnSpacing="10">
                <StackPanel Spacing="4">
                    <TextBlock Text="Account name"
                               FontSize="12"
                               Foreground="#475569"/>
                    <TextBox MinHeight="40"
                             PlaceholderText="Name"
                             Text="{Binding NewAccountName}"
                             Background="White"
                             Foreground="#111827"
                             BorderBrush="#94A3B8"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Spacing="4">
                    <TextBlock Text="Type"
                               FontSize="12"
                               Foreground="#475569"/>
                    <ComboBox MinHeight="40"
                              ItemsSource="{Binding AccountTypes}"
                              SelectedItem="{Binding SelectedAccountType}"
                              Background="White"
                              Foreground="#111827"
                              BorderBrush="#94A3B8"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Spacing="4">
                    <TextBlock Text="Subtype"
                               FontSize="12"
                               Foreground="#475569"/>
                    <TextBox MinHeight="40"
                             PlaceholderText="Optional"
                             Text="{Binding AccountSubtype}"
                             Background="White"
                             Foreground="#111827"
                             BorderBrush="#94A3B8"/>
                </StackPanel>

                <Button Grid.Column="3"
                        MinHeight="40"
                        MinWidth="110"
                        Margin="0,20,0,0"
                        Command="{Binding CreateAccountCommand}"
                        Content="Add account"
                        Background="#2563EB"
                        Foreground="White"/>
            </Grid>

            <Grid Grid.Row="1"
                  ColumnDefinitions="*,Auto,Auto,Auto"
                  ColumnSpacing="10">
                <TextBlock Text="Select an account below to rename or deactivate it."
                           VerticalAlignment="Center"
                           Foreground="#64748B"/>
                <Button Grid.Column="1"
                        MinHeight="36"
                        Command="{Binding SeedDefaultAccountsCommand}"
                        Content="Add default accounts"
                        Background="White"
                        Foreground="#0F172A"
                        BorderBrush="#94A3B8"/>
                <Button Grid.Column="2"
                        MinHeight="36"
                        MinWidth="90"
                        Command="{Binding RenameSelectedAccountCommand}"
                        Content="Rename"
                        Background="White"
                        Foreground="#0F172A"
                        BorderBrush="#94A3B8"/>
                <Button Grid.Column="3"
                        MinHeight="36"
                        MinWidth="100"
                        Command="{Binding DeactivateSelectedAccountCommand}"
                        Content="Deactivate"
                        Background="White"
                        Foreground="#0F172A"
                        BorderBrush="#94A3B8"/>
            </Grid>

            <Grid Grid.Row="2"
                  RowDefinitions="38,*">
                <Border Background="#E9EEF5"
                        BorderBrush="#CBD5E1"
                        BorderThickness="1">
                    <Grid Margin="12,0"
                          ColumnDefinitions="2*,130,170,100"
                          ColumnSpacing="14">
                        <TextBlock Text="Account"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="#334155"/>
                        <TextBlock Grid.Column="1"
                                   Text="Type"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="#334155"/>
                        <TextBlock Grid.Column="2"
                                   Text="Subtype"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="#334155"/>
                        <TextBlock Grid.Column="3"
                                   Text="Status"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="#334155"/>
                    </Grid>
                </Border>

                <ListBox Grid.Row="1"
                         MinHeight="320"
                         Background="White"
                         Foreground="#111827"
                         BorderBrush="#CBD5E1"
                         ItemsSource="{Binding Accounts}"
                         SelectedItem="{Binding SelectedAccount}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="api:AccountSummary">
                            <Grid Margin="12,8"
                                  ColumnDefinitions="2*,130,170,100"
                                  ColumnSpacing="14">
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold"
                                           Foreground="#111827"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding AccountType}"
                                           Foreground="#334155"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding AccountSubtype}"
                                           Foreground="#475569"/>
                                <CheckBox Grid.Column="3"
                                          IsChecked="{Binding IsActive}"
                                          IsEnabled="False"
                                          Content="Active"
                                          Foreground="#475569"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
