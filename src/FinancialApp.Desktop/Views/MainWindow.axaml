<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FinancialApp.Desktop.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="FinancialApp.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="920"
        Height="560"
        MinWidth="720"
        MinHeight="420"
        Title="{Binding Title}">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*"
          Background="#F6F7F9">
        <Border Grid.Row="0"
                Background="#1E293B"
                Padding="24,18">
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding Title}"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Bookkeeping desktop foundation"
                           Foreground="#CBD5E1"
                           FontSize="14"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1"
              ColumnDefinitions="220,*">
            <Border Background="#E9EDF2"
                    Padding="18">
                <StackPanel Spacing="12">
                    <TextBlock Text="Dashboard"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Transactions"/>
                    <TextBlock Text="Imports"/>
                    <TextBlock Text="Accounts"/>
                    <TextBlock Text="Reports"/>
                    <TextBlock Text="Settings"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="1"
                        Margin="32"
                        Spacing="16"
                        VerticalAlignment="Center">
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="22"
                           FontWeight="SemiBold"/>
                <TextBlock Text="{Binding DatabaseSummary}"
                           FontSize="14"
                           Foreground="#475569"/>
                <TextBlock Text="{Binding ApiHealthMessage}"
                           FontSize="14"
                           Foreground="#475569"/>
            </StackPanel>
        </Grid>
    </Grid>

</Window>
