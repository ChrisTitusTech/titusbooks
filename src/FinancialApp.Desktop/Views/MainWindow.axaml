<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FinancialApp.Desktop.ViewModels"
        xmlns:views="using:FinancialApp.Desktop.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1280"
        d:DesignHeight="800"
        x:Class="FinancialApp.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="1280"
        Height="800"
        MinWidth="1120"
        MinHeight="680"
        Title="{Binding Title}">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Button.nav">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="MinHeight" Value="48"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#C9D6E3"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="0"/>
        </Style>
        <Style Selector="Button.nav:pointerover">
            <Setter Property="Background" Value="#203F58"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.nav.active">
            <Setter Property="Background" Value="#078CB5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="190,*"
          Background="#F4F6F8">
        <Border Background="#17354D">
            <Grid RowDefinitions="64,*,Auto">
                <Border Background="#102A3E"
                        Padding="16,0">
                    <Grid ColumnDefinitions="36,*"
                          ColumnSpacing="10"
                          VerticalAlignment="Center">
                        <Border Width="34"
                                Height="34"
                                Background="#28A66A"
                                CornerRadius="17">
                            <TextBlock Text="T"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Title}"
                                   VerticalAlignment="Center"
                                   FontSize="19"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="1"
                            Margin="0,8,0,0">
                    <Button Classes="nav"
                            Classes.active="{Binding IsHomePage}"
                            Content="Home"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Home"/>
                    <Button Classes="nav"
                            Classes.active="{Binding IsTransactionsPage}"
                            Content="Transactions"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Transactions"/>
                    <Button Classes="nav"
                            Classes.active="{Binding IsAccountsPage}"
                            Content="Accounts"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Accounts"/>
                    <Button Classes="nav"
                            Classes.active="{Binding IsReportsPage}"
                            Content="Reports"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Reports"/>
                    <Button Classes="nav"
                            Classes.active="{Binding IsImportsPage}"
                            Content="Imports"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Imports"/>
                    <Button Classes="nav"
                            Classes.active="{Binding IsReconciliationPage}"
                            Content="Reconciliation"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Reconciliation"/>

                    <Border Height="1"
                            Margin="18,12"
                            Background="#31516A"/>

                    <Button Classes="nav"
                            Classes.active="{Binding IsSetupPage}"
                            Content="Company settings"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Setup"/>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Margin="18,18,18,22"
                            Spacing="5">
                    <TextBlock Text="{Binding ApiHealthMessage}"
                               TextWrapping="Wrap"
                               FontSize="11"
                               Foreground="#C9D6E3"/>
                    <TextBlock Text="{Binding ApiEndpointSummary}"
                               TextWrapping="Wrap"
                               FontSize="10"
                               Foreground="#83A1B7"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1"
              RowDefinitions="54,Auto,Auto,*">
            <Border Background="#E7EDF4"
                    BorderBrush="#D1DAE4"
                    BorderThickness="0,0,0,1"
                    Padding="24,0">
                <Grid ColumnDefinitions="*,Auto,Auto"
                      ColumnSpacing="10"
                      VerticalAlignment="Center">
                    <TextBlock Text="{Binding PageDescription}"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="#526579"/>
                    <Button Grid.Column="1"
                            MinHeight="34"
                            MinWidth="148"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Transactions"
                            Content="+  New transaction"
                            Background="#078CB5"
                            Foreground="White"/>
                    <Button Grid.Column="2"
                            MinHeight="34"
                            Command="{Binding NavigateCommand}"
                            CommandParameter="Setup"
                            Content="Settings"
                            Background="White"
                            Foreground="#334155"
                            BorderBrush="#B9C6D3"/>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="White"
                    BorderBrush="#E1E6EC"
                    BorderThickness="0,0,0,1"
                    Padding="28,20">
                <Grid ColumnDefinitions="*,280"
                      ColumnSpacing="24">
                    <StackPanel Spacing="3">
                        <TextBlock Text="{Binding PageTitle}"
                                   FontSize="25"
                                   FontWeight="SemiBold"
                                   Foreground="#172033"/>
                        <TextBlock Text="{Binding DashboardPeriod}"
                                   IsVisible="{Binding IsHomePage}"
                                   FontSize="12"
                                   Foreground="#64748B"/>
                    </StackPanel>

                    <ComboBox Grid.Column="1"
                              MinHeight="36"
                              ItemsSource="{Binding Organizations}"
                              SelectedItem="{Binding SelectedOrganization}"
                              Background="White"
                              Foreground="#111827"
                              BorderBrush="#B9C6D3">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="#111827"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Margin="28,14,28,14"
                    Padding="11,8"
                    Background="#EAF3F8"
                    BorderBrush="#C7DCE8"
                    BorderThickness="1">
                <TextBlock Text="{Binding WorkspaceMessage}"
                           TextWrapping="Wrap"
                           FontSize="12"
                           Foreground="#28526A"/>
            </Border>

            <Grid Grid.Row="3">
                <views:HomeView IsVisible="{Binding IsHomePage}"/>
                <views:SetupView IsVisible="{Binding IsSetupPage}"/>
                <views:AccountsView IsVisible="{Binding IsAccountsPage}"/>
                <views:TransactionsView IsVisible="{Binding IsTransactionsPage}"/>
                <views:ImportsView IsVisible="{Binding IsImportsPage}"/>
                <views:ReportsView IsVisible="{Binding IsReportsPage}"/>
                <views:ReconciliationView IsVisible="{Binding IsReconciliationPage}"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
