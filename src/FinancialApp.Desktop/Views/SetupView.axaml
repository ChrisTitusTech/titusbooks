<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FinancialApp.Desktop.ViewModels"
             xmlns:api="using:FinancialApp.Core.Api"
             x:Class="FinancialApp.Desktop.Views.SetupView"
             x:DataType="vm:MainWindowViewModel">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="32,0,32,32"
              RowDefinitions="Auto,Auto,Auto"
              RowSpacing="24">
            <Border Padding="20"
                    Background="White"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                      RowSpacing="12">
                    <StackPanel Spacing="3">
                        <TextBlock Text="Secure API connection"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="#0F172A"/>
                        <TextBlock Text="The desktop app stores this API address only. PostgreSQL credentials stay on the API host."
                                   TextWrapping="Wrap"
                                   Foreground="#475569"/>
                    </StackPanel>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="12">
                        <TextBox MinHeight="42"
                                 PlaceholderText="https://books.example.com"
                                 Text="{Binding ApiBaseUrl}"
                                 Background="White"
                                 Foreground="#111827"
                                 BorderBrush="#94A3B8"/>
                        <Button Grid.Column="1"
                                MinHeight="42"
                                MinWidth="140"
                                Command="{Binding SaveApiSettingsCommand}"
                                Content="Save API URL"
                                Background="#2563EB"
                                Foreground="White"/>
                    </Grid>

                    <CheckBox Grid.Row="2"
                              IsChecked="{Binding AllowInsecureRemoteHttp}"
                              Content="Allow HTTP to another computer (development only)"
                              Foreground="#334155"/>

                    <TextBlock Grid.Row="3"
                               Text="{Binding ApiTransportMessage}"
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="#9A3412"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1"
                  ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <TextBox MinHeight="42"
                         PlaceholderText="Company name"
                         Text="{Binding NewOrganizationName}"
                         Background="White"
                         Foreground="#111827"
                         BorderBrush="#94A3B8"/>
                <Button Grid.Column="1"
                        MinHeight="42"
                        MinWidth="160"
                        Command="{Binding CreateOrganizationCommand}"
                        Content="Create company"
                        Background="#2563EB"
                        Foreground="White"/>
            </Grid>

            <Grid Grid.Row="2"
                  RowDefinitions="Auto,*"
                  RowSpacing="10"
                  MinHeight="390">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Companies"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"/>
                    <Button Grid.Column="1"
                            MinHeight="34"
                            Command="{Binding LoadOrganizationsCommand}"
                            Content="Refresh"
                            Background="White"
                            Foreground="#0F172A"
                            BorderBrush="#94A3B8"/>
                </Grid>

                <ListBox Grid.Row="1"
                         Background="White"
                         Foreground="#111827"
                         BorderBrush="#CBD5E1"
                         ItemsSource="{Binding Organizations}"
                         SelectedItem="{Binding SelectedOrganization}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="api:OrganizationSummary">
                            <Grid Margin="12,9"
                                  ColumnDefinitions="*,120,180"
                                  ColumnSpacing="18">
                                <TextBlock Text="{Binding Name}"
                                           FontWeight="SemiBold"
                                           Foreground="#111827"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding BaseCurrency}"
                                           Foreground="#475569"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding AccountingMethod}"
                                           Foreground="#475569"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
