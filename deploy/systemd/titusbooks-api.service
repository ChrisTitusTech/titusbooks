[Unit]
Description=TitusBooks API
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
WorkingDirectory=/opt/titusbooks/api
ExecStart=/usr/bin/dotnet /opt/titusbooks/api/FinancialApp.Api.dll
EnvironmentFile=/etc/titusbooks/api.env
Restart=always
RestartSec=5
User=titus
Group=titus
UMask=0077
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict

[Install]
WantedBy=multi-user.target
